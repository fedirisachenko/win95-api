{
    "name": "win95",
    "version": "0.0.1",
    "description": "",
    "author": "",
    "private": true,
    "license": "UNLICENSED",
    "scripts": {
        "build": "nest build",
        "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
        "start": "nest start",
        "start:dev": "nest start --watch",
        "start:debug": "nest start --debug --watch",
        "start:prod": "node dist/apps/win95/main",
        "start:dev:all": "nest start --watch chat & nest start --watch matchmaking & nest start --watch client",
        "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
        "test:e2e": "jest --config ./apps/win95/test/jest-e2e.json",
        "migration:create": "node -r dotenv/config -r ts-node/register ./node_modules/.bin/mikro-orm migration:create",
        "migration:up": "node -r dotenv/config -r ts-node/register ./node_modules/.bin/mikro-orm migration:up",
        "migration:down": "node -r dotenv/config -r ts-node/register ./node_modules/.bin/mikro-orm migration:down",
        "migration:list": "node -r dotenv/config -r ts-node/register ./node_modules/.bin/mikro-orm migration:list",
        "seeder:run": "node -r dotenv/config -r ts-node/register ./node_modules/.bin/mikro-orm seeder:run"
    },
    "dependencies": {
        "@bull-board/api": "^6.20.6",
        "@bull-board/express": "^6.20.6",
        "@bull-board/nestjs": "^6.20.6",
        "@mikro-orm/core": "^6.5.6",
        "@mikro-orm/migrations": "^6.5.6",
        "@mikro-orm/nestjs": "^6.1.1",
        "@mikro-orm/postgresql": "^6.5.6",
        "@mikro-orm/seeder": "^6.5.6",
        "@nestjs/axios": "^4.0.1",
        "@nestjs/bullmq": "^11.0.4",
        "@nestjs/common": "^11.0.1",
        "@nestjs/config": "^4.0.2",
        "@nestjs/core": "^11.0.1",
        "@nestjs/jwt": "^11.0.0",
        "@nestjs/microservices": "^11.1.17",
        "@nestjs/platform-express": "^11.0.1",
        "@nestjs/platform-socket.io": "^11.1.16",
        "@nestjs/websockets": "^11.1.16",
        "@songkeys/nestjs-redis": "^11.0.0",
        "@types/bcrypt": "^6.0.0",
        "amqp-connection-manager": "^5.0.0",
        "amqplib": "^1.0.2",
        "axios": "^1.13.6",
        "bcrypt": "^6.0.0",
        "bullmq": "^5.71.1",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.3",
        "dotenv": "^17.2.2",
        "ioredis": "^5.9.2",
        "nestjs-asyncapi": "^1.4.0",
        "pg": "^8.16.3",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.1",
        "socket.io": "^4.8.3",
        "uuid": "^8.3.2"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.2.0",
        "@eslint/js": "^9.18.0",
        "@mikro-orm/cli": "^6.5.6",
        "@nestjs/cli": "^11.0.0",
        "@nestjs/passport": "^11.0.5",
        "@nestjs/schematics": "^11.0.0",
        "@nestjs/swagger": "^11.2.0",
        "@nestjs/testing": "^11.0.1",
        "@types/express": "^5.0.0",
        "@types/jest": "^30.0.0",
        "@types/node": "^22.10.7",
        "@types/supertest": "^6.0.2",
        "@types/uuid": "^10.0.0",
        "eslint": "^9.18.0",
        "eslint-config-prettier": "^10.0.1",
        "eslint-plugin-prettier": "^5.2.2",
        "globals": "^16.0.0",
        "jest": "^30.0.0",
        "prettier": "^3.4.2",
        "source-map-support": "^0.5.21",
        "supertest": "^7.0.0",
        "ts-jest": "^29.2.5",
        "ts-loader": "^9.5.2",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.7.3",
        "typescript-eslint": "^8.20.0"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": ".",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "collectCoverageFrom": [
            "**/*.(t|j)s"
        ],
        "coverageDirectory": "./coverage",
        "testEnvironment": "node",
        "roots": [
            "<rootDir>/apps/",
            "<rootDir>/libs/"
        ],
        "moduleNameMapper": {
            "^@apps/orm(|/.*)$": "<rootDir>/libs/orm/src/$1",
            "^libs/core(|/.*)$": "<rootDir>/libs/core/src/$1",
            "^libs/security(|/.*)$": "<rootDir>/libs/security/src/$1"
        }
    },
    "mikro-orm": {
        "useTsNode": true,
        "configPaths": [
            "./config/mikro-orm.config.ts"
        ]
    }
}
