{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "allowJs": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "es2017",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictBindCallApply": true,
    "paths": {
      "@apps/core": [
        "apps/core/src/*"
      ],
      "@apps/database/*": [
        "apps/database/src/*"
      ],
      "@config/*": [
        "config/*"
      ],
      "@libs/orm": [
        "libs/orm/src"
      ],
      "@libs/orm/*": [
        "libs/orm/src/*"
      ],
      "@libs/core": [
        "libs/core/src"
      ],
      "@libs/core/*": [
        "libs/core/src/*"
      ]
    }
  }
}