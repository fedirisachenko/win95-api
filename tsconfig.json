{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "allowJs": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "es2017",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictBindCallApply": true,
    "paths": {
      "@config/*": [
        "config/*"
      ],
      "@libs/core": [
        "libs/core/src"
      ],
      "@libs/core/*": [
        "libs/core/src/*"
      ],
      "@libs/notification": [
        "libs/notification/src"
      ],
      "@libs/notification/*": [
        "libs/notification/src/*"
      ],
      "@libs/orm": [
        "libs/orm/src"
      ],
      "@libs/orm/*": [
        "libs/orm/src/*"
      ],
      "@libs/security": [
        "libs/security/src"
      ],
      "@libs/security/*": [
        "libs/security/src/*"
      ],
      "@libs/ws": [
        "libs/ws/src"
      ],
      "@libs/ws/*": [
        "libs/ws/src/*"
      ],
      "@libs/rmq": [
        "libs/rmq/src"
      ],
      "@libs/rmq/*": [
        "libs/rmq/src/*"
      ]
    }
  }
}